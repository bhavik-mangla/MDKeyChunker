# LLM Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic, custom
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini  # For OpenAI; or claude-3-haiku-20240307 for Anthropic
LLM_CALL_BUDGET_PER_DOC=50  # Maximum LLM calls per document (0=no LLM)

# Entity Extraction
ENTITY_EXTRACTION_MODE=spacy  # Options: spacy, none
SPACY_MODEL=en_core_web_sm  # Download with: python -m spacy download en_core_web_sm
STRICT_ENTITY_MODE=true  # Filter out common/generic words as entities

# Chunking Parameters
MIN_CHUNK_SIZE=100  # Minimum characters per chunk
SOFT_MAX_CHUNK_SIZE=1000  # Preferred maximum chunk size
HARD_MAX_CHUNK_SIZE=2000  # Absolute maximum chunk size
CHUNK_MAX_TOKENS=512  # Target tokens for embedding models

# Pass-Keys-Forward Configuration
PASS_KEYS_FORWARD=true  # Enable pass-keys-forward linking
BACKWARD_PASS=false  # Enable backward pass for late references
MAX_KEYS_MEMORY=100  # Maximum keys to keep in rolling memory

# Scoring Weights (must sum to reasonable total, e.g., ~1.0)
ENTITY_WEIGHT=0.4  # Weight for entity overlap
KEYWORD_WEIGHT=0.3  # Weight for keyword overlap
PROXIMITY_WEIGHT=0.2  # Weight for proximity decay
REF_WEIGHT=0.1  # Weight for referential signals (this, above, etc.)

# Thresholds
THRESHOLD_ACCEPT=0.6  # Score >= this: accept key linkage
THRESHOLD_REJECT=0.3  # Score < this: reject key linkage
# Between these: use LLM if budget allows

# Optional Features
ENABLE_QUESTIONS=false  # Generate questions per chunk (requires LLM)
DUPLICATE_DETECTION=true  # Detect and optionally dedupe identical chunks
REMOVE_HEADERS_FOOTERS=true  # Detect and remove repeating headers/footers

# Performance
MULTIPROCESSING=false  # Enable parallel processing for large docs
MAX_WORKERS=4  # Number of worker processes

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=mdkeychunker.log  # Optional log file (leave empty for stdout only)

# Generic Entity Blacklist (comma-separated, case-insensitive)
ENTITY_BLACKLIST=system,process,data,information,document,section,chapter,page,example,item,thing,way,time,year,day,case,part,point,fact
